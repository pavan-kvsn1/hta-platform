# =============================================================================
# HTA Platform - Production Environment Configuration
# =============================================================================
# Copy this file to terraform.tfvars and fill in your values.
# NEVER commit terraform.tfvars to git (it's in .gitignore).
# =============================================================================

# GCP Project
project_id  = "hta-platform-prod"
region      = "asia-south1"  # Mumbai - primary region for India
environment = "production"

# Network (defaults are fine for most cases)
subnet_cidr   = "10.0.0.0/20"
pods_cidr     = "10.4.0.0/14"
services_cidr = "10.8.0.0/20"

# GKE Configuration
gke_node_count   = 1                # Start with 1, autoscaler handles scaling
gke_machine_type = "e2-standard-4"  # 4 vCPU, 16GB RAM
gke_disk_size_gb = 50
gke_node_locations = ["asia-south1-b","asia-south1-c"],   # Multi-zone HA

# Cloud SQL Configuration
cloudsql_tier      = "db-custom-2-4096"  # 2 vCPU, 4GB RAM
cloudsql_disk_size = 100                  # 50GB as planned
database_name      = "hta_platform"
database_user      = "hta_app"
database_password  = "hta_calibration_0809"

# Redis Configuration
redis_tier           = "STANDARD_HA"  # HA for production
redis_memory_size_gb = 1

# Cloud Armor (optional - block specific IPs)
blocked_ip_ranges = []  # e.g., ["1.2.3.4/32", "5.6.7.0/24"]

# Storage - CORS origins for production domains
cors_origins = [
  "https://app.hta-calibration.com",
  "https://hta-calibration.com"
]

# Kubernetes namespace
k8s_namespace = "hta-prod"

# GitHub (for Workload Identity Federation)
github_repo = "pavan-kvsn1/hta-platform"

# IAP (Identity-Aware Proxy) for Argo CD access
iap_support_email = "admin@htaipl.com"
iap_authorized_members = [
  "user:kvsn.pvn@gmail.com",
  "user:prakash@htaipl.com",
  # Add more team members who need Argo CD access:
  # "user:teammate@gmail.com",
]

# Disaster Recovery
enable_dr_replica = false        # Set to true when needed (~$30/month extra)
dr_replica_region = "asia-south2"  # Delhi - secondary region

# Monitoring
monitoring_notification_channels = []  # Add notification channel IDs from GCP Console
enable_pagerduty      = false
pagerduty_service_key = ""  # PagerDuty integration key if enabled

# =============================================================================
# Estimated Monthly Cost: ~$150 (~₹12,000)
# =============================================================================
# GKE (e2-standard-4 x1 + sustained use):  ~$50
# Cloud SQL (db-custom-2-4096, 50GB):      ~$45
# Redis (STANDARD_HA 1GB):                 ~$35
# Cloud NAT:                               ~$5
# GCS + Static IP + Cloud Armor:           ~$15
# =============================================================================
