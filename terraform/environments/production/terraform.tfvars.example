# =============================================================================
# Production Environment Variables
# =============================================================================
# Copy this file to terraform.tfvars and fill in the values

project_id  = "your-gcp-project-id"
region      = "us-central1"
environment = "production"

# Network
subnet_cidr   = "10.0.0.0/20"
pods_cidr     = "10.4.0.0/14"
services_cidr = "10.8.0.0/20"

# GKE
gke_node_count   = 2
gke_machine_type = "e2-standard-4"
gke_disk_size_gb = 50
gke_node_locations = ["us-central1-a", "us-central1-b"]

# Cloud SQL
cloudsql_tier      = "db-custom-2-4096"
cloudsql_disk_size = 20
database_name      = "hta_platform"
database_user      = "hta_app"
database_password  = "CHANGE_ME_USE_STRONG_PASSWORD"

# Redis
redis_tier           = "STANDARD_HA"
redis_memory_size_gb = 1

# Cloud Armor (optional - block specific IPs)
blocked_ip_ranges = []  # e.g., ["1.2.3.4/32", "5.6.7.0/24"]

# Storage
cors_origins = ["https://app.hta-platform.com"]

# Kubernetes
k8s_namespace = "hta-platform"

# GitHub (for Workload Identity Federation)
github_repo = "your-org/hta-platform"

# IAP (Identity-Aware Proxy) for Argo CD
iap_support_email = "your-email@gmail.com"
iap_authorized_members = [
  "user:your-email@gmail.com",
  # Add more team members:
  # "user:teammate@gmail.com",
]
