    },
    "./logger": {
      "types": "./src/logger/index.ts",
      "import": "./dist/logger/index.js"
    },
    "./cache": {
      "types": "./src/cache/index.ts",
      "import": "./dist/cache/index.js"
    },
    "./security": {
      "types": "./src/security/index.ts",
      "import": "./dist/security/index.js"
    },
    "./tenant": {
      "types": "./src/tenant/index.ts",
      "import": "./dist/tenant/index.js"
    },
    "./types": {
      "types": "./src/types/index.ts",
      "import": "./dist/types/index.js"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "import": "./dist/utils/index.js"
    },
    "./audit": {
      "types": "./src/audit/index.ts",
      "import": "./dist/audit/index.js"
    },
    "./notifications": {
      "types": "./src/notifications/index.ts",
      "import": "./dist/notifications/index.js"
    },
    "./sentry": {
      "types": "./src/sentry/index.ts",
      "import": "./dist/sentry/index.js"
    },
    "./health": {
      "types": "./src/health/index.ts",
      "import": "./dist/health/index.js"
    },
    "./metrics": {
      "types": "./src/metrics/index.ts",
      "import": "./dist/metrics/index.js"
    },
    "./alerting": {
      "types": "./src/alerting/index.ts",
