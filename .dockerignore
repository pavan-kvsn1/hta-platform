# Dependencies (will be installed in container)
node_modules
**/node_modules

# Build outputs (will be rebuilt in container)
dist
**/dist
.next
**/.next

# Development files
.git
.gitignore
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# IDE and editor files
.idea
.vscode
*.swp
*.swo

# Test files
tests
**/tests
**/*.test.ts
**/*.spec.ts
coverage
**/coverage

# Documentation
docs
*.md
!README.md

# OS files
.DS_Store
Thumbs.db

# Turborepo
.turbo
**/.turbo

# Claude Code worktrees (contain old/experimental code)
.claude
.claude/
.claude/**
**/.claude
**/.claude/**

# Misc
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
