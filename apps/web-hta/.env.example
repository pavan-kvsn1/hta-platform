# ===========================================
# HTA Platform - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values

# Database (GCP Cloud SQL or local PostgreSQL)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public"

# Authentication (NextAuth.js)
# Generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-key-here"
NEXTAUTH_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY="re_xxxxxxxxxxxx"
EMAIL_FROM="noreply@yourdomain.com"

# Storage (for certificate images/PDFs)
STORAGE_PROVIDER="LOCAL"  # LOCAL or GCP
CERTIFICATE_STORAGE_PATH="./storage/master-instrument-certificates"
# GCP_BUCKET_NAME="your-bucket-name"
# GCP_PROJECT_ID="your-project-id"

# Redis (optional - for caching/rate limiting)
# REDIS_URL="redis://localhost:6379"

# Environment
NODE_ENV="development"
