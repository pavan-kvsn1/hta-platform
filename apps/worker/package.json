{
  "name": "@hta/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "dependencies": {
    "@hta/database": "workspace:*",
    "@hta/shared": "workspace:*",
    "@hta/emails": "workspace:*",
    "bullmq": "^5.0.0",
    "ioredis": "^5.4.0",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsc-alias": "^1.8.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
