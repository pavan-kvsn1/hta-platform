# =============================================================================
# HTA Platform - Environment Variables (Docker Compose)
# =============================================================================
# Copy this file to .env and fill in the values
# Used by: docker-compose.yml
# =============================================================================

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_USER=hta_user
POSTGRES_PASSWORD=hta_dev_password
POSTGRES_DB=hta_platform
DATABASE_URL=postgresql://hta_user:hta_dev_password@postgres:5432/hta_platform

# For local development (without Docker):
# DATABASE_URL=postgresql://hta_user:hta_dev_password@localhost:5432/hta_platform

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# For local development (without Docker):
# REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-super-secret-key-change-in-production
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=HTA Calibration <noreply@hta-calibration.com>

# -----------------------------------------------------------------------------
# Storage (GCS in production, local in development)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=LOCAL
# For GCS:
# STORAGE_PROVIDER=GCS
# GCS_BUCKET_NAME=your-bucket-name
# GCS_PROJECT_ID=your-project-id

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------
API_URL=http://api:8080
# For local development (without Docker):
# API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Node Environment
# -----------------------------------------------------------------------------
NODE_ENV=development
